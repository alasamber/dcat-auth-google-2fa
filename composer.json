{
    "name": "alasamber/dcat-auth-google-2fa",
    "alias": "Auth Google 2FA两步验证",
    "description": "Dcat-Admin auth verification by Google 2FA / Dcat-Admin 登录 Google 2FA两步验证",
    "type": "library",
    "keywords": [
        "dcat-admin",
        "extension",
        "google",
        "auth",
        "2fa",
        "login",
        "captcha"
    ],
    "homepage": "https://github.com/alasamber/dcat-auth-google-2fa",
    "license": "MIT",
    "authors": [
        {
            "name": "alasamber",
            "email": "vivian666@mr.email"
        }
    ],
    "require": {
        "php": ">=7.1.0",
        "bacon/bacon-qr-code": "^3.0",
        "pragmarx/google2fa-qrcode": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Alasamber\\DcatAuthGoogle2Fa\\": "src/"
        }
    },
    "extra": {
        "dcat-admin": "Alasamber\\DcatAuthGoogle2Fa\\DcatAuthGoogle2FaServiceProvider",
        "laravel": {
            "providers": [
                "Alasamber\\DcatAuthGoogle2Fa\\DcatAuthGoogle2FaServiceProvider"
            ]
        }
    }
}
